#!/usr/bin/env python3
"""niblet-program — parse and validate .niblet/program.md."""

import argparse
import re
import sys
from pathlib import Path


def parse_program(path: Path) -> dict:
    content = path.read_text(encoding="utf-8")
    sections = {}
    current = None
    buffer = []
    for line in content.splitlines():
        match = re.match(r"^##\s+(.+)$", line)
        if match:
            if current is not None:
                sections[current] = "\n".join(buffer).strip()
            current = match.group(1).lower().replace(" ", "_")
            buffer = []
        elif current is not None:
            buffer.append(line)
    if current is not None:
        sections[current] = "\n".join(buffer).strip()
    return sections


def validate_program(sections: dict) -> list:
    required = ["mission", "knowledge_taxonomy", "auto-write_policy"]
    return [key for key in required if key not in sections]


def main() -> int:
    parser = argparse.ArgumentParser(description="Parse .niblet/program.md")
    parser.add_argument("--project-root", required=True, help="absolute project root")
    parser.add_argument("--key", help="print value of a single section")
    parser.add_argument("--validate", action="store_true", help="validate required sections")
    args = parser.parse_args()

    project_root = Path(args.project_root).resolve()
    if not project_root.is_dir():
        print(f"error: not a directory: {project_root}", file=sys.stderr)
        return 66

    program_path = project_root / ".niblet" / "program.md"
    if not program_path.is_file():
        print(f"missing: {program_path}", file=sys.stderr)
        return 66

    sections = parse_program(program_path)

    if args.validate:
        missing = validate_program(sections)
        if missing:
            print(f"invalid: missing sections {missing}", file=sys.stderr)
            return 65
        print("valid")
        return 0

    if args.key:
        print(sections.get(args.key, ""))
        return 0

    print(f"program: {program_path}")
    print(f"sections: {len(sections)}")
    for key, value in sections.items():
        print(f"\n## {key}\n{value}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
