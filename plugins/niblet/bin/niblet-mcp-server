#!/usr/bin/env bash
# niblet-mcp-server — MCP stdio server for Kimi Code CLI.
#
# Exposes niblet tools via the Model Context Protocol (JSON-RPC 2.0 over stdin/stdout).
# Tools: niblet_log, niblet_apply, niblet_status, niblet_promote.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)"

command -v jq >/dev/null 2>&1 || {
  echo '{"jsonrpc":"2.0","error":{"code":-32603,"message":"jq required"}}' >&2
  exit 1
}

send() {
  printf '%s\n' "$1"
}

json_id() {
  # JSON-RPC id may be a string, number, or null; always serialize it as a
  # JSON value so a string id like "abc" becomes "abc" and a numeric id 1
  # stays 1. Empty id means a notification — caller must handle that case.
  printf '%s' "$1" | jq -R . 2>/dev/null
}

mcp_error() {
  local id="$1" code="$2" message="$3"
  if [ -n "$id" ]; then
    send "{\"jsonrpc\":\"2.0\",\"id\":$(json_id "$id"),\"error\":{\"code\":$code,\"message\":$(jq -sR . <<< "$message")}}"
  fi
}

handle_initialize() {
  local id="$1" payload="$2"
  local protocol_version
  # Echo back the protocol version requested by the client; kimi-code 0.14.3
  # sends "2025-11-25" and expects the server to agree.
  protocol_version="$(printf '%s' "$payload" | jq -r '.params.protocolVersion // "2024-11-05"')"
  send "{\"jsonrpc\":\"2.0\",\"id\":$(json_id "$id"),\"result\":{\"protocolVersion\":$(printf '%s' "$protocol_version" | jq -R .),\"capabilities\":{\"tools\":{}},\"serverInfo\":{\"name\":\"niblet\",\"version\":\"0.6.0\"}}}"
}

handle_tools_list() {
  local id="$1"
  local tools
  tools='[
    {
      "name": "niblet_log",
      "description": "Append a sanitized tool-use event to the session raw log (.niblet/raw/<session>.jsonl). Call after every file-mutating tool (WriteFile, StrReplaceFile, Edit) so niblet can later extract reusable patterns.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": {"type": "string", "description": "Current session ID"},
          "tool": {"type": "string", "description": "Tool name that was used, e.g. WriteFile, StrReplaceFile, Bash"},
          "path": {"type": "string", "description": "Project-relative file path affected by the tool, if any"},
          "exit_code": {"type": "string", "description": "Exit code for Bash tools, empty string otherwise"},
          "success": {"type": "boolean", "description": "Whether the tool reported success"},
          "project_root": {"type": "string", "description": "Absolute path to the project root (optional; defaults to git toplevel or $PWD"}
        },
        "required": ["session_id", "tool"]
      }
    },
    {
      "name": "niblet_apply",
      "description": "Secure write entry point for niblet actions. Reads an ACTION JSON object and either writes to the project KB/memory (auto-write tier) or stages a proposal for human review (proposal tier). Always use this instead of direct WriteFile/Edit for KB, memory, skills, agents, commands, scripts, or CLAUDE.md/AGENTS.md.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project_root": {"type": "string", "description": "Absolute path to the project root"},
          "action": {"type": "object", "description": "The niblet ACTION JSON object. Examples: {\"action\":\"ADD_KB_ENTRY\",\"scope\":\"project\",\"topic\":\"auth.md\",\"content\":\"...\"} or {\"action\":\"UPDATE_MEMORY\",\"scope\":\"project\",\"file\":\"feedback_wtf.md\",\"content\":\"...\"}"}
        },
        "required": ["action"]
      }
    },
    {
      "name": "niblet_status",
      "description": "Print a project dashboard: KB count, memory files, pending proposals, promoted artifacts, queue depths. Emits only counts and paths — never file content.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project_root": {"type": "string", "description": "Absolute path to the project root (optional; defaults to git toplevel or $PWD"}
        }
      }
    },
    {
      "name": "niblet_promote",
      "description": "Promote a pending proposal file to its target artifact. Action-aware: strips envelope, validates syntax, creates backups before overwrites. Never use raw mv for proposals.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "proposal_file": {"type": "string", "description": "Absolute path to the proposal .md file inside .niblet/proposals/"},
          "project_root": {"type": "string", "description": "Absolute path to the project root (optional; defaults to git toplevel or $PWD"}
        },
        "required": ["proposal_file"]
      }
    },
    {
      "name": "niblet_capture_task",
      "description": "Record a completed agent task, its components, skills used, files touched, outcome, and optional user feedback. Writes a task record to .niblet/tasks/<session>.jsonl and skill usage metrics to .niblet/metrics/skills.jsonl. Call once at the end of a task instead of logging every tool call.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project_root": {"type": "string", "description": "Absolute path to the project root"},
          "session_id": {"type": "string", "description": "Current session ID"},
          "summary": {"type": "string", "description": "One-sentence summary of what the task accomplished"},
          "components": {"type": "array", "items": {"type": "string"}, "description": "Component slugs touched in this task"},
          "skills": {"type": "array", "items": {"type": "string"}, "description": "Skills or pipelines used during the task"},
          "files_read": {"type": "array", "items": {"type": "string"}, "description": "Project-relative file paths read"},
          "files_modified": {"type": "array", "items": {"type": "string"}, "description": "Project-relative file paths modified"},
          "outcome": {"type": "string", "enum": ["success", "failure", "cancelled"], "description": "Task outcome"},
          "feedback": {"type": "string", "description": "Optional user feedback; written to memory if outcome is failure or cancelled"}
        },
        "required": ["project_root", "session_id"]
      }
    },
    {
      "name": "niblet_capture_read",
      "description": "Record that the agent read or edited a file. Niblet tracks how many files have been touched per component and queues a code-walker job when a component has been explored enough. This is the KB-as-side-effect path: durable knowledge is created while the agent reads files for its actual tasks.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project_root": {"type": "string", "description": "Absolute path to the project root"},
          "session_id": {"type": "string", "description": "Current session ID"},
          "path": {"type": "string", "description": "Project-relative file path that was read or edited"},
          "tool": {"type": "string", "enum": ["Read", "Edit", "Write", "MultiEdit", "NotebookEdit"], "description": "Tool that touched the file"}
        },
        "required": ["project_root", "session_id", "path"]
      }
    },
    {
      "name": "niblet_run_pipeline",
      "description": "Print a named niblet pipeline and record that it was used. Pipelines are reusable workflows stored under .niblet/pipelines/.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project_root": {"type": "string", "description": "Absolute path to the project root"},
          "session_id": {"type": "string", "description": "Current session ID"},
          "name": {"type": "string", "description": "Pipeline name"},
          "success": {"type": "boolean", "description": "Whether the pipeline run succeeded", "default": true}
        },
        "required": ["project_root", "session_id", "name"]
      }
    }
  ]'
  # MCP stdio transport expects each JSON-RPC message on a single line (NDJSON).
  send "{\"jsonrpc\":\"2.0\",\"id\":$(json_id "$id"),\"result\":{\"tools\":$(printf '%s' "$tools" | jq -c .)}}"

}

handle_tools_call() {
  local id="$1" payload="$2"
  local name args tmpfile exit_code output stderr

  name="$(printf '%s' "$payload" | jq -r '.params.name // empty')"
  args="$(printf '%s' "$payload" | jq -c '.params.arguments // {}')"

  case "$name" in
    niblet_log)
      tmpfile="$(mktemp)"
      printf '%s' "$args" > "$tmpfile"
      set +e
      output="$("$SCRIPT_DIR/niblet-log" < "$tmpfile" 2>"$tmpfile.stderr")"
      exit_code=$?
      stderr="$(cat "$tmpfile.stderr" 2>/dev/null || true)"
      set -e
      rm -f "$tmpfile" "$tmpfile.stderr"
      ;;
    niblet_apply)
      tmpfile="$(mktemp)"
      printf '%s' "$args" > "$tmpfile"
      set +e
      output="$("$SCRIPT_DIR/niblet-apply-kimi" < "$tmpfile" 2>"$tmpfile.stderr")"
      exit_code=$?
      stderr="$(cat "$tmpfile.stderr" 2>/dev/null || true)"
      set -e
      rm -f "$tmpfile" "$tmpfile.stderr"
      ;;
    niblet_status)
      tmpfile="$(mktemp)"
      printf '%s' "$args" > "$tmpfile"
      set +e
      output="$("$SCRIPT_DIR/niblet-status-kimi" < "$tmpfile" 2>"$tmpfile.stderr")"
      exit_code=$?
      stderr="$(cat "$tmpfile.stderr" 2>/dev/null || true)"
      set -e
      rm -f "$tmpfile" "$tmpfile.stderr"
      ;;
    niblet_promote)
      tmpfile="$(mktemp)"
      printf '%s' "$args" > "$tmpfile"
      set +e
      output="$("$SCRIPT_DIR/niblet-promote-kimi" < "$tmpfile" 2>"$tmpfile.stderr")"
      exit_code=$?
      stderr="$(cat "$tmpfile.stderr" 2>/dev/null || true)"
      set -e
      rm -f "$tmpfile" "$tmpfile.stderr"
      ;;
    niblet_capture_task)
      project_root="$(printf '%s' "$args" | jq -r '.project_root // empty')"
      session_id="$(printf '%s' "$args" | jq -r '.session_id // empty')"
      summary="$(printf '%s' "$args" | jq -r '.summary // empty')"
      components="$(printf '%s' "$args" | jq -r '(.components // []) | join(",")')"
      skills="$(printf '%s' "$args" | jq -r '(.skills // []) | join(",")')"
      files_read="$(printf '%s' "$args" | jq -r '(.files_read // []) | join(",")')"
      files_modified="$(printf '%s' "$args" | jq -r '(.files_modified // []) | join(",")')"
      outcome="$(printf '%s' "$args" | jq -r '.outcome // "success"')"
      feedback="$(printf '%s' "$args" | jq -r '.feedback // empty')"
      stderr_file="$(mktemp)"
      set +e
      output="$("$SCRIPT_DIR/niblet-capture-task" \
        --project-root "$project_root" \
        --session-id "$session_id" \
        --summary "$summary" \
        --components "$components" \
        --skills "$skills" \
        --files-read "$files_read" \
        --files-modified "$files_modified" \
        --outcome "$outcome" \
        --feedback "$feedback" 2>"$stderr_file")"
      exit_code=$?
      stderr="$(cat "$stderr_file" 2>/dev/null || true)"
      set -e
      rm -f "$stderr_file"
      ;;
    niblet_capture_read)
      project_root="$(printf '%s' "$args" | jq -r '.project_root // empty')"
      session_id="$(printf '%s' "$args" | jq -r '.session_id // empty')"
      read_path="$(printf '%s' "$args" | jq -r '.path // empty')"
      tool_name="$(printf '%s' "$args" | jq -r '.tool // "Read"')"
      stderr_file="$(mktemp)"
      set +e
      output="$("$SCRIPT_DIR/niblet-capture-read" \
        --project-root "$project_root" \
        --session "$session_id" \
        --path "$read_path" \
        --tool "$tool_name" 2>"$stderr_file")"
      exit_code=$?
      stderr="$(cat "$stderr_file" 2>/dev/null || true)"
      set -e
      rm -f "$stderr_file"
      ;;
    niblet_run_pipeline)
      project_root="$(printf '%s' "$args" | jq -r '.project_root // empty')"
      session_id="$(printf '%s' "$args" | jq -r '.session_id // empty')"
      pipeline_name="$(printf '%s' "$args" | jq -r '.name // empty')"
      pipeline_success="$(printf '%s' "$args" | jq -r '.success // true')"
      stderr_file="$(mktemp)"
      set +e
      output="$("$SCRIPT_DIR/niblet-pipelines" \
        --project-root "$project_root" \
        run \
        --name "$pipeline_name" \
        --session-id "$session_id" \
        --success "$pipeline_success" 2>"$stderr_file")"
      exit_code=$?
      stderr="$(cat "$stderr_file" 2>/dev/null || true)"
      set -e
      rm -f "$stderr_file"
      ;;
    "")
      mcp_error "$id" -32600 "Missing tool name"
      return
      ;;
    *)
      mcp_error "$id" -32601 "Unknown tool: $name"
      return
      ;;
  esac

  local text is_error
  text="$output"
  if [ -n "$stderr" ]; then
    text="${text:+$text
}$stderr"
  fi
  [ -n "$text" ] || text="ok"

  if [ "$exit_code" -ne 0 ]; then
    is_error="true"
  else
    is_error="false"
  fi

  send "{\"jsonrpc\":\"2.0\",\"id\":$(json_id "$id"),\"result\":{\"content\":[{\"type\":\"text\",\"text\":$(jq -sR . <<< "$text")}],\"isError\":$is_error}}"
}

main() {
  local line id method payload
  while IFS= read -r line || [ -n "$line" ]; do
    # Strip carriage returns and surrounding whitespace to be resilient to
    # CRLF and leading/trailing spaces from the MCP client.
    line="$(printf '%s' "$line" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    [ -n "$line" ] || continue
    id="$(printf '%s' "$line" | jq -r '.id // empty')"
    method="$(printf '%s' "$line" | jq -r '.method // empty')"

    case "$method" in
      initialize)
        handle_initialize "$id" "$line"
        ;;
      tools/list)
        handle_tools_list "$id"
        ;;
      tools/call)
        handle_tools_call "$id" "$line"
        ;;
      "")
        # Empty/malformed method with id: protocol error
        [ -z "$id" ] || mcp_error "$id" -32600 "Invalid Request"
        ;;
      *)
        # Notifications (no id) are ignored; unknown methods with id return method not found
        if [ -n "$id" ]; then
          mcp_error "$id" -32601 "Method not found: $method"
        fi
        ;;
    esac
  done
}

main
