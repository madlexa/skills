#!/usr/bin/env bash
# niblet-apply — the single secure entry point for ACTION writes.
#
# The parent agent reads ACTION JSON lines from the niblet-deep sub-agent and
# pipes each line to this script via the Bash tool. The script validates the
# action and either writes it to its target (auto-write tier) or stages it
# as a proposal (proposal tier). All filename inputs are slug-validated and
# all final paths are canonicalised + containment-checked, so a malicious
# `topic` / `name` / `file` value cannot escape the allowed directory.
#
# Usage:
#   # Step 1 (Write tool): stage the ACTION JSON to a file. Write does
#   # NOT shell-interpret content, so single quotes / metacharacters in
#   # the payload are safe.
#   #   .niblet/inbox/<random>.json   ← JSON object goes here
#   #
#   # Step 2 (Bash tool): feed the file via stdin redirection.
#   niblet-apply --project-root <abs-path> < .niblet/inbox/<random>.json
#
# Never `echo '<json>' | niblet-apply` — a single quote inside content
# closes the shell literal and runs whatever follows BEFORE the helper
# validates anything. Always Write-then-stdin.
#
# Output:
#   On success:  "applied: <action> -> <target>"   or
#                "proposal: <action> -> <proposal-path>"
#   On any rejection: "rejected: <reason>" (exit non-zero)
#
# Never writes outside the project's .claude/ or .niblet/proposals/ tree,
# or the user's ~/.claude/ or ~/.niblet-proposals/ tree for global scope.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)"
. "$SCRIPT_DIR/../lib/sanitize.sh"
. "$SCRIPT_DIR/../lib/store.sh"

# ---- args ----
PROJECT_ROOT=""
while [ $# -gt 0 ]; do
  case "$1" in
    --project-root) PROJECT_ROOT="$2"; shift 2 ;;
    *) printf 'unknown arg: %s\n' "$1" >&2; exit 64 ;;
  esac
done

JSON="$(cat)"
[ -n "$JSON" ] || {
  echo "rejected: empty stdin." >&2
  echo "  Usage: niblet-apply --project-root <abs-path> < <inbox-file>.json" >&2
  echo "  Never \`echo '<json>' | niblet-apply\` — shell metachars in content" >&2
  echo "  can break out of single quotes. Write the JSON to a file first." >&2
  exit 64
}

command -v jq >/dev/null 2>&1 || { echo "rejected: jq is required" >&2; exit 70; }

# Auto-detect project root from $PWD if not given.
[ -n "$PROJECT_ROOT" ] || PROJECT_ROOT="$(niblet_project_root "$PWD")"
[ -d "$PROJECT_ROOT" ] || { echo "rejected: project_root not a directory: $PROJECT_ROOT" >&2; exit 66; }

ACTION="$(printf '%s' "$JSON" | jq -r '.action // empty')"
SCOPE="$( printf '%s' "$JSON" | jq -r '.scope  // "project"')"
NAME="$(  printf '%s' "$JSON" | jq -r '.name   // empty')"
TOPIC="$( printf '%s' "$JSON" | jq -r '.topic  // empty')"
FILE="$(  printf '%s' "$JSON" | jq -r '.file   // empty')"
SECTION="$(printf '%s' "$JSON" | jq -r '.section // empty')"
ADDITION="$(printf '%s' "$JSON" | jq -r '.addition // empty')"
CONTENT="$( printf '%s' "$JSON" | jq -r '.content  // empty')"
REASON="$(  printf '%s' "$JSON" | jq -r '.reason   // empty')"
CONFIDENCE="$(       printf '%s' "$JSON" | jq -r '.confidence        // empty')"
RISK="$(             printf '%s' "$JSON" | jq -r '.risk              // empty')"
SOURCE_SESSIONS="$(  printf '%s' "$JSON" | jq -r '.source_sessions   // empty')"
SOURCE_KB="$(        printf '%s' "$JSON" | jq -r '.source_kb         // empty')"
BEGINNER_SUMMARY="$( printf '%s' "$JSON" | jq -r '.beginner_summary  // empty')"
VALIDATION_DETAILS="$(printf '%s' "$JSON" | jq -r '.validation_details // empty')"
EVIDENCE="$(        printf '%s' "$JSON" | jq -r '.evidence          // empty')"

[ -n "$ACTION" ] || { echo "rejected: no action field" >&2; exit 65; }
case "$SCOPE" in project|global) ;; *) echo "rejected: scope must be project|global" >&2; exit 65 ;; esac

# Slug-validate the user-supplied name field (action-specific).
validate_or_proposal() {
  local what="$1" val="$2"
  if ! niblet_validate_slug "$val"; then
    proposal "invalid-slug:$what=$val"
    return 1
  fi
}

# Tally proposals dir creation.
PROPOSALS_DIR_PROJECT="$(niblet_store "$PROJECT_ROOT")/proposals"
PROPOSALS_DIR_GLOBAL="$HOME/.niblet-proposals"

niblet_ensure_store "$PROJECT_ROOT" >/dev/null

ts() { date -u +%Y%m%dT%H%M%SZ; }

# Sanitize a scalar value for use in a frontmatter field: take only the first
# line (strip from first newline) and remove bare CR. Prevents multi-line
# values from injecting extra frontmatter fields into proposal envelopes.
_fe() { local _v="${1%%$'\n'*}"; printf '%s' "${_v%$'\r'}"; }

write_proposal() {
  local target_dir="$1" reason="$2" target_path="$3"
  mkdir -p "$target_dir" 2>/dev/null

  # Build a slug for the filename. Prefer the action's natural identifier
  # (NAME / TOPIC / FILE). For UPDATE_CLAUDE, derive from SECTION. Falls
  # back to "unnamed" so the filename is never bare "<ts>-<ACTION>-.md".
  local slug_src="$NAME$TOPIC$FILE"
  if [ -z "$slug_src" ] && { [ "$ACTION" = "UPDATE_CLAUDE" ] || [ "$ACTION" = "UPDATE_AGENTS" ]; }; then
    slug_src="$SECTION"
  fi
  local slug
  slug="$(printf '%s' "$slug_src" \
    | LC_ALL=C tr '[:upper:]' '[:lower:]' \
    | LC_ALL=C tr -c 'a-z0-9._-' '-' \
    | tr -s '-' \
    | sed 's/^-//;s/-$//' \
    | LC_ALL=C cut -c -32)"
  [ -z "$slug" ] && slug="unnamed"

  # Strip path separators from ACTION so a malicious unknown action like
  # "../../escape" cannot make proposal_path resolve outside target_dir.
  # Known actions contain only [A-Z_] so stripping "/" leaves them unchanged.
  local safe_action
  safe_action="$(printf '%s' "${ACTION%%$'\n'*}" | LC_ALL=C tr -d '\r/' | LC_ALL=C cut -c -32)"
  [ -z "$safe_action" ] && safe_action="unknown"

  local base="$(ts)-${safe_action}-${slug}"
  local proposal_path="$target_dir/${base}.md"
  local i=1
  # Write content to a temp file first, then atomically claim an available
  # name via mv -n. This eliminates the TOCTOU race between the collision
  # check and the write when two concurrent niblet-apply calls produce the
  # same base name in the same second.
  local _tmp_prop
  _tmp_prop="$(mktemp "$target_dir/XXXXXXXX.tmp" 2>/dev/null)" || _tmp_prop="$target_dir/.tmp-$$-$(ts)"
  {
    echo "---"
    echo "action: $(_fe "$ACTION")"
    echo "scope: $(_fe "$SCOPE")"
    [ -n "$target_path" ] && echo "target: $(_fe "$target_path")"
    [ -n "$reason" ]      && echo "rejected_reason: $(_fe "$reason")"
    echo "created: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    [ -n "$NAME" ]             && echo "name: $(_fe "$NAME")"
    [ -n "$TOPIC" ]            && echo "topic: $(_fe "$TOPIC")"
    [ -n "$FILE" ]             && echo "file: $(_fe "$FILE")"
    [ -n "$SECTION" ]          && echo "section: $(_fe "$SECTION")"
    [ -n "$CONFIDENCE" ]       && echo "confidence: $(_fe "$CONFIDENCE")"
    [ -n "$REASON" ]           && echo "reason: $(_fe "$REASON")"
    [ -n "$EVIDENCE" ]         && echo "evidence: $(_fe "$EVIDENCE")"
    [ -n "$RISK" ]             && echo "risk: $(_fe "$RISK")"
    [ -n "$SOURCE_SESSIONS" ]  && echo "source_sessions: $(_fe "$SOURCE_SESSIONS")"
    [ -n "$SOURCE_KB" ]        && echo "source_kb: $(_fe "$SOURCE_KB")"
    [ -n "$VALIDATION_DETAILS" ] && echo "validation: $(_fe "$VALIDATION_DETAILS")"
    if [ "${NIBLET_BEGINNER_UX:-0}" = "1" ] && [ -n "$BEGINNER_SUMMARY" ]; then
      echo "has_beginner_summary: true"
    fi
    echo "---"
    if [ "${NIBLET_BEGINNER_UX:-0}" = "1" ] && [ -n "$BEGINNER_SUMMARY" ]; then
      # Strip marker strings so summary content cannot close the skip block early
      # and have text promoted as artifact content (injection via end-marker escape).
      _safe_bsum="$(printf '%s' "$BEGINNER_SUMMARY" \
        | grep -vF '<!-- NIBLET BEGINNER SUMMARY -->' \
        | grep -vF '<!-- END NIBLET BEGINNER SUMMARY -->' \
        || true)"
      printf '\n<!-- NIBLET BEGINNER SUMMARY -->\n%s\n<!-- END NIBLET BEGINNER SUMMARY -->\n\n' "$_safe_bsum"
    fi
    if [ "$ACTION" = "UPDATE_CLAUDE" ] || [ "$ACTION" = "UPDATE_AGENTS" ]; then
      printf '%s\n' "$ADDITION"
    else
      printf '%s\n' "$CONTENT"
    fi
  } > "$_tmp_prop"
  local _mv_tries=0
  local _linked=0
  while [ "$_mv_tries" -lt 50 ]; do
    # ln uses link() which is POSIX-atomic: fails with EEXIST if target
    # already exists, eliminating the TOCTOU race that mv -n cannot prevent
    # portably on BSD/macOS. Both paths are in $target_dir so same fs.
    if ln "$_tmp_prop" "$proposal_path" 2>/dev/null; then
      rm -f "$_tmp_prop" 2>/dev/null || true
      _linked=1
      break
    fi
    i=$((i + 1))
    proposal_path="$target_dir/${base}-${i}.md"
    _mv_tries=$((_mv_tries + 1))
  done
  if [ "$_linked" = "0" ]; then
    echo "error: write_proposal: failed to claim a proposal path after 50 attempts" >&2
    rm -f "$_tmp_prop" 2>/dev/null || true
    exit 1
  fi
  echo "proposal: $ACTION -> $proposal_path"
  exit 0
}

proposal() {
  local reason="$1"
  local target_dir="$PROPOSALS_DIR_PROJECT"
  [ "$SCOPE" = "global" ] && target_dir="$PROPOSALS_DIR_GLOBAL"
  write_proposal "$target_dir" "$reason" ""
}

write_auto() {
  local target_path="$1" allowed_root="$2"
  # Defence in depth: refuse to write through a symlink even if the
  # canonicalizer said the target is inside allowed_root. A pre-existing
  # symlink in the path can let a "safe" write land elsewhere on disk.
  if ! niblet_assert_no_symlink_in_path "$target_path" "$allowed_root" 2>/dev/null; then
    proposal "symlink-in-path:target=$target_path"
    return
  fi
  mkdir -p "$(dirname "$target_path")" 2>/dev/null
  printf '%s\n' "$CONTENT" > "$target_path"
  echo "applied: $ACTION -> $target_path"
}

# Append the body of a memory feedback entry to an existing file, preserving
# the original frontmatter. If the file does not exist yet, write the full
# content (frontmatter + body). This ensures repeated corrections accumulate
# instead of overwriting the previous one.
append_memory_file() {
  local target_path="$1" allowed_root="$2"
  if ! niblet_assert_no_symlink_in_path "$target_path" "$allowed_root" 2>/dev/null; then
    proposal "symlink-in-path:target=$target_path"
    return
  fi
  mkdir -p "$(dirname "$target_path")" 2>/dev/null
  if [ -f "$target_path" ]; then
    # Strip the frontmatter from the incoming content (if present) and append
    # only the body. Content without frontmatter is appended as-is.
    local new_body
    new_body="$(printf '%s\n' "$CONTENT" | awk '/^---$/ { c++; next } c >= 2 { print }')"
    # If there was no frontmatter (no second ---), append the whole content.
    if [ -z "$new_body" ] && ! printf '%s\n' "$CONTENT" | awk 'BEGIN{found=0} /^---$/ { found++; if (found>=2) exit } END{exit found>=2 ? 0 : 1}' >/dev/null 2>&1; then
      new_body="$CONTENT"
    fi
    if [ -n "$new_body" ]; then
      printf '\n%s\n' "$new_body" >> "$target_path"
    fi
  else
    printf '%s\n' "$CONTENT" > "$target_path"
  fi
  echo "applied: $ACTION -> $target_path"
}

# ---- dispatch ----
case "$ACTION" in
  NOTHING)
    echo "applied: NOTHING reason=${REASON:-unspecified}"
    exit 0
    ;;

  ADD_KB_ENTRY)
    [ "$SCOPE" = "project" ] || proposal "global-kb-needs-review"
    niblet_validate_slug "$TOPIC" || proposal "invalid-slug:topic=$TOPIC"
    KB="$(niblet_artifact_dir kb project "$PROJECT_ROOT")"
    target="$KB/$TOPIC"
    case "$target" in *.md) ;; *) target="$target.md" ;; esac
    niblet_assert_under_dir "$target" "$KB" 2>/dev/null || proposal "path-escape:topic=$TOPIC"
    write_auto "$target" "$KB"
    ;;

  UPDATE_MEMORY)
    [ "$SCOPE" = "project" ] || proposal "global-memory-needs-review"
    niblet_validate_slug "$FILE" || proposal "invalid-slug:file=$FILE"
    MEM="$(niblet_artifact_dir memory project "$PROJECT_ROOT")"
    target="$MEM/$FILE"
    case "$target" in *.md) ;; *) target="$target.md" ;; esac
    niblet_assert_under_dir "$target" "$MEM" 2>/dev/null || proposal "path-escape:file=$FILE"
    append_memory_file "$target" "$MEM"
    ;;

  CREATE_SKILL|CREATE_COMMAND)
    niblet_validate_slug "$NAME" || proposal "invalid-slug:name=$NAME"
    if [ "$ACTION" = "CREATE_SKILL" ]; then
      base="$(niblet_artifact_dir skills "$SCOPE" "$PROJECT_ROOT")"
      target="$base/$NAME/SKILL.md"
    else
      base="$(niblet_artifact_dir commands "$SCOPE" "$PROJECT_ROOT")"
      target="$base/$NAME.md"
    fi
    niblet_assert_under_dir "$target" "$base" 2>/dev/null || proposal "path-escape:name=$NAME"
    # Skills/commands/CLAUDE.md/global are PROPOSAL tier — always proposal even when valid.
    target_dir="$PROPOSALS_DIR_PROJECT"
    [ "$SCOPE" = "global" ] && target_dir="$PROPOSALS_DIR_GLOBAL"
    write_proposal "$target_dir" "" "$target"
    ;;

  CREATE_AGENT)
    niblet_validate_slug "$NAME" || proposal "invalid-slug:name=$NAME"
    base="$(niblet_artifact_dir agents "$SCOPE" "$PROJECT_ROOT")"
    target="$base/$NAME.md"
    niblet_assert_under_dir "$target" "$base" 2>/dev/null || proposal "path-escape:name=$NAME"
    target_dir="$PROPOSALS_DIR_PROJECT"
    [ "$SCOPE" = "global" ] && target_dir="$PROPOSALS_DIR_GLOBAL"
    write_proposal "$target_dir" "" "$target"
    ;;

  CREATE_SCRIPT)
    niblet_validate_slug "$NAME" || proposal "invalid-slug:name=$NAME"
    base="$(niblet_artifact_dir scripts "$SCOPE" "$PROJECT_ROOT")"
    target="$base/$NAME"
    niblet_assert_under_dir "$target" "$base" 2>/dev/null || proposal "path-escape:name=$NAME"
    # Validate the script content syntax before staging as proposal.
    _tmp_script="$(mktemp)"
    printf '%s\n' "$CONTENT" > "$_tmp_script"
    _val_result="fail"
    _val_msg=""
    case "$NAME" in
      *.py)
        if python3 -m py_compile "$_tmp_script" 2>/dev/null; then
          _val_result="pass"
        else
          _val_msg="$(python3 -m py_compile "$_tmp_script" 2>&1 || true)"
        fi
        ;;
      *)
        if bash -n "$_tmp_script" 2>/dev/null; then
          _val_result="pass"
        else
          _val_msg="$(bash -n "$_tmp_script" 2>&1 || true)"
        fi
        ;;
    esac
    rm -f "$_tmp_script"
    VALIDATION_DETAILS="${_val_result}${_val_msg:+: ${_val_msg}}"
    target_dir="$PROPOSALS_DIR_PROJECT"
    [ "$SCOPE" = "global" ] && target_dir="$PROPOSALS_DIR_GLOBAL"
    write_proposal "$target_dir" "" "$target"
    ;;

  UPDATE_SKILL|UPDATE_AGENT|UPDATE_COMMAND|UPDATE_SCRIPT)
    niblet_validate_slug "$NAME" || proposal "invalid-slug:name=$NAME"
    case "$ACTION" in
      UPDATE_SKILL)   base="$(niblet_artifact_dir skills   "$SCOPE" "$PROJECT_ROOT")" ;;
      UPDATE_AGENT)   base="$(niblet_artifact_dir agents   "$SCOPE" "$PROJECT_ROOT")" ;;
      UPDATE_COMMAND) base="$(niblet_artifact_dir commands "$SCOPE" "$PROJECT_ROOT")" ;;
      UPDATE_SCRIPT)  base="$(niblet_artifact_dir scripts  "$SCOPE" "$PROJECT_ROOT")" ;;
    esac
    case "$ACTION" in
      UPDATE_SKILL)   target="$base/$NAME/SKILL.md" ;;
      UPDATE_AGENT)   target="$base/$NAME.md" ;;
      UPDATE_COMMAND) target="$base/$NAME.md" ;;
      UPDATE_SCRIPT)  target="$base/$NAME" ;;
    esac
    niblet_assert_under_dir "$target" "$base" 2>/dev/null || proposal "path-escape:name=$NAME"
    if [ "$ACTION" = "UPDATE_SCRIPT" ]; then
      _tmp_script="$(mktemp)"
      printf '%s\n' "$CONTENT" > "$_tmp_script"
      _val_result="fail"
      _val_msg=""
      case "$NAME" in
        *.py)
          if python3 -m py_compile "$_tmp_script" 2>/dev/null; then
            _val_result="pass"
          else
            _val_msg="$(python3 -m py_compile "$_tmp_script" 2>&1 || true)"
          fi
          ;;
        *)
          if bash -n "$_tmp_script" 2>/dev/null; then
            _val_result="pass"
          else
            _val_msg="$(bash -n "$_tmp_script" 2>&1 || true)"
          fi
          ;;
      esac
      rm -f "$_tmp_script"
      VALIDATION_DETAILS="${_val_result}${_val_msg:+: ${_val_msg}}"
    fi
    target_dir="$PROPOSALS_DIR_PROJECT"
    [ "$SCOPE" = "global" ] && target_dir="$PROPOSALS_DIR_GLOBAL"
    write_proposal "$target_dir" "" "$target"
    ;;

  MERGE_KB_ENTRY|UPDATE_KB_ENTRY)
    [ "$SCOPE" = "project" ] || proposal "global-kb-needs-review"
    niblet_validate_slug "$TOPIC" || proposal "invalid-slug:topic=$TOPIC"
    KB="$(niblet_artifact_dir kb project "$PROJECT_ROOT")"
    target="$KB/$TOPIC"
    case "$target" in *.md) ;; *) target="$target.md" ;; esac
    niblet_assert_under_dir "$target" "$KB" 2>/dev/null || proposal "path-escape:topic=$TOPIC"
    write_auto "$target" "$KB"
    ;;

  DEPRECATE_KB_ENTRY)
    [ "$SCOPE" = "project" ] || proposal "global-kb-needs-review"
    niblet_validate_slug "$TOPIC" || proposal "invalid-slug:topic=$TOPIC"
    KB="$(niblet_artifact_dir kb project "$PROJECT_ROOT")"
    target="$KB/$TOPIC"
    case "$target" in *.md) ;; *) target="$target.md" ;; esac
    niblet_assert_under_dir "$target" "$KB" 2>/dev/null || proposal "path-escape:topic=$TOPIC"
    if ! niblet_assert_no_symlink_in_path "$target" "$KB" 2>/dev/null; then
      proposal "symlink-in-path:target=$target"
    fi
    mkdir -p "$(dirname "$target")" 2>/dev/null
    _dep_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    _dep_tmp="$(mktemp "$KB/.XXXXXXXX.tmp" 2>/dev/null)" || _dep_tmp="$KB/.dep-$$-${_dep_ts}.tmp"
    if [ -f "$target" ]; then
      { printf '<!-- DEPRECATED %s -->\n' "$_dep_ts"; cat "$target"; } > "$_dep_tmp" \
        && mv "$_dep_tmp" "$target" || { rm -f "$_dep_tmp"; false; }
    else
      printf '<!-- DEPRECATED %s -->\n%s\n' "$_dep_ts" "${CONTENT:-deprecated}" > "$_dep_tmp" \
        && mv "$_dep_tmp" "$target" || { rm -f "$_dep_tmp"; false; }
    fi
    echo "applied: $ACTION -> $target"
    ;;

  OPEN_QUESTION|AUDIT_REPORT)
    target_dir="$PROPOSALS_DIR_PROJECT"
    [ "$SCOPE" = "global" ] && target_dir="$PROPOSALS_DIR_GLOBAL"
    write_proposal "$target_dir" "" ""
    ;;

  UPDATE_CLAUDE|UPDATE_AGENTS)
    [ "$SCOPE" = "project" ] || proposal "global-runtime-md-not-supported"
    [ -n "$SECTION" ]  || proposal "missing-section"
    [ -n "$ADDITION" ] || proposal "missing-addition"
    if [ "$ACTION" = "UPDATE_CLAUDE" ]; then
      target="$PROJECT_ROOT/CLAUDE.md"
    else
      target="$PROJECT_ROOT/AGENTS.md"
    fi
    write_proposal "$PROPOSALS_DIR_PROJECT" "" "$target"
    ;;

  *)
    proposal "unknown-action"
    ;;
esac
