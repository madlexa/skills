#!/usr/bin/env bash
# niblet-apply-kimi — Kimi plugin wrapper for niblet-apply.
#
# Kimi passes all tool parameters as a single JSON object on stdin.
# We extract `project_root` and `action`, then feed the action JSON
# to the canonical niblet-apply via stdin.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)"

INPUT="$(cat 2>/dev/null || true)"
[ -n "$INPUT" ] || { echo "rejected: empty stdin" >&2; exit 64; }

command -v jq >/dev/null 2>&1 || { echo "rejected: jq required" >&2; exit 70; }

PROJECT_ROOT="$(printf '%s' "$INPUT" | jq -r '.project_root // empty')"
ACTION_JSON="$(printf '%s' "$INPUT" | jq -c '.action // empty')"

[ -n "$PROJECT_ROOT" ] || PROJECT_ROOT="$(cd "$PWD" 2>/dev/null && git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")"
[ -n "$ACTION_JSON" ] && [ "$ACTION_JSON" != "null" ] || { echo "rejected: missing action JSON" >&2; exit 65; }

# Force the Kimi runtime regardless of ambient env or sibling runtime dirs.
# Without this override niblet-apply falls back to Claude when no KIMI_SESSION
# env var is present, causing Kimi wrapper writes to land under .claude/.
(
  export NIBLET_RUNTIME=kimi
  printf '%s\n' "$ACTION_JSON" | "$SCRIPT_DIR/niblet-apply" --project-root "$PROJECT_ROOT"
)
